{
  "version": 2,
  "builds": [
    {
      "src": "server/src/app.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/src/app.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/internal/cron/auto-approve",
      "schedule": "0 * * * *"
    }
  ]
}
