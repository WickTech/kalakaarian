# =============================================================================
# Kalakaarian — environment template
# Copy to `.env` for local dev (and `server/.env` if your runner reads it there).
# Never commit real secrets. Production secrets live in Vercel project settings.
# =============================================================================

# ---- Runtime ----
NODE_ENV=development
PORT=4000

# ---- Supabase ----
# Project URL and keys from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# ---- CORS ----
# Comma-separated allowlist. Server reads CORS_ORIGINS (plural).
# Example: https://kalakaarian.vercel.app,https://www.kalakaarian.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Google OAuth ----
# Register your app in Supabase Dashboard → Auth → Providers → Google, then enable Google provider.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ---- WhatsApp Cloud API (optional — needed for notifications) ----
# Leave blank in dev to fall through to mock OTP path.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-string

# ---- Social platforms (optional — used by influencer connect-social flow) ----
INSTAGRAM_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# ---- Email (Resend) ----
# Used to send OTP emails and notifications. Get key at resend.com.
RESEND_API_KEY=re_your_resend_api_key

# ---- Payments (Razorpay) ----
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ---- Monitoring (Sentry — optional) ----
SENTRY_DSN=

# ---- Frontend (Vite) ----
# Vite-only vars MUST be prefixed with VITE_. These are baked into the bundle
# at build time, so do NOT put secrets here.
VITE_API_URL=http://localhost:4000/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
