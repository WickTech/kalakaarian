# ===========================================
# KALAKARIAAN ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# BACKEND (Express API)
# ===========================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB - Local Development
# MONGODB_URI=mongodb://localhost:27017/kalakariaan

# MongoDB - Production (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kalakariaan?retryWrites=true&w=majority

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# CORS - Add your frontend URLs
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ===========================================
# FRONTEND (React/Vite)
# ===========================================

# API URL - Update for production
VITE_API_URL=http://localhost:5000/api

# For Vercel Production:
# VITE_API_URL=https://your-railway-app.railway.app/api

# ===========================================
# PRODUCTION URLs (Update after deployment)
# ===========================================

# Frontend URL (for CORS on backend)
PRODUCTION_FRONTEND_URL=https://your-app.vercel.app

# Backend URL (for frontend API calls)
PRODUCTION_BACKEND_URL=https://your-railway-app.railway.app
