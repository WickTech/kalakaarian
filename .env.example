# =============================================================================
# Kalakaarian — environment template
# Copy to `.env` for local dev (and `server/.env` if your runner reads it there).
# Never commit real secrets. Production secrets live in Vercel project settings.
# =============================================================================

# ---- Runtime ----
NODE_ENV=development
PORT=4000

# ---- MongoDB ----
# Local:    mongodb://localhost:27017/kalakaarian
# Atlas:    mongodb+srv://<user>:<pass>@<cluster>/kalakaarian?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/kalakaarian

# ---- Auth ----
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex
JWT_EXPIRES_IN=7d

# ---- CORS ----
# Comma-separated allowlist. Server reads CORS_ORIGINS (plural).
# Example: https://kalakaarian.vercel.app,https://www.kalakaarian.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Google OAuth ----
# OAuth client ID from console.cloud.google.com (Web application credential)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ---- WhatsApp Cloud API (optional — needed for OTP + notifications) ----
# Leave blank in dev to fall through to mock OTP path.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-string

# ---- Social platforms (optional — used by influencer connect-social flow) ----
INSTAGRAM_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# ---- Frontend (Vite) ----
# Vite-only vars MUST be prefixed with VITE_. These are baked into the bundle
# at build time, so do NOT put secrets here.
VITE_API_URL=http://localhost:4000/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
